#!/bin/bash

clear
echo "================================"
echo "AUTO FIX WINGS PTERODACTYL PRO"
echo "================================"

sleep 2

echo "Update package..."
apt update -y
apt install curl certbot tar unzip -y

echo "================================"
echo "Memastikan docker aktif..."
echo "================================"

if ! command -v docker &> /dev/null
then
echo "Docker belum ada, install docker..."
curl -fsSL https://get.docker.com | sh
fi

systemctl enable docker
systemctl start docker

echo "Docker status:"
systemctl is-active docker

echo "================================"
echo "Install Wings..."
echo "================================"

if ! command -v wings &> /dev/null
then
curl -L -o /usr/local/bin/wings https://github.com/pterodactyl/wings/releases/latest/download/wings_linux_amd64
chmod +x /usr/local/bin/wings
fi

echo "================================"
echo "Membuat service wings..."
echo "================================"

cat <<EOF > /etc/systemd/system/wings.service
[Unit]
Description=Pterodactyl Wings Daemon
After=docker.service
Requires=docker.service

[Service]
User=root
WorkingDirectory=/etc/pterodactyl
ExecStart=/usr/local/bin/wings
Restart=always
RestartSec=5
LimitNOFILE=4096

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload

echo "================================"
echo "Menyiapkan folder wings..."
echo "================================"

mkdir -p /etc/pterodactyl
mkdir -p /var/lib/pterodactyl
mkdir -p /var/lib/pterodactyl/volumes
mkdir -p /var/log/pterodactyl
mkdir -p /run/wings

echo "================================"
echo "Fix permission..."
echo "================================"

chown -R 988:988 /var/lib/pterodactyl 2>/dev/null
chmod -R 755 /var/lib/pterodactyl

echo "================================"
echo "Fix SSH key (SFTP error)..."
echo "================================"

rm -f /etc/ssh/ssh_host_*
ssh-keygen -A

chmod 600 /etc/ssh/ssh_host_*_key
chmod 644 /etc/ssh/ssh_host_*_key.pub

systemctl restart ssh

echo "================================"
echo "Generate machine-id..."
echo "================================"

systemd-machine-id-setup

echo "================================"
echo "Restart nginx (fix web panel)..."
echo "================================"

if ! command -v nginx &> /dev/null
then
echo "Install nginx..."
apt install nginx -y
fi

systemctl enable nginx
systemctl restart nginx

echo "================================"
echo "Cek config wings..."
echo "================================"

if [ ! -f "/etc/pterodactyl/config.yml" ]; then
echo ""
echo "CONFIG WINGS BELUM ADA"
echo "Jalankan command ini:"
echo ""
echo "cd /etc/pterodactyl && wings configure --panel-url https://DOMAIN --token TOKEN --node ID"
echo ""
fi

echo "================================"
echo "Menjalankan wings..."
echo "================================"

systemctl enable wings
systemctl restart wings

sleep 3

echo "================================"
echo "STATUS SERVICE"
echo "================================"

echo "Docker:"
systemctl status docker --no-pager
echo ""

echo "Nginx:"
systemctl status nginx --no-pager
echo ""

echo "Wings:"
systemctl status wings --no-pager

echo "================================"
echo "FIX WINGS SELESAI"
echo "================================"
