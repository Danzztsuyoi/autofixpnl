#!/bin/bash

clear
echo "================================"
echo "AUTO FIX WINGS PTERODACTYL"
echo "================================"

sleep 2

echo "Memastikan docker aktif..."

systemctl start docker 2>/dev/null
systemctl enable docker 2>/dev/null

if ! systemctl is-active --quiet docker; then
echo "Docker belum aktif, menginstall docker..."

curl -fsSL https://get.docker.com | sh

systemctl daemon-reload
systemctl enable docker
systemctl start docker
fi

echo "Docker status:"
systemctl is-active docker

echo "Masuk ke folder pterodactyl..."

mkdir -p /etc/pterodactyl
cd /etc/pterodactyl

echo "Menjalankan configure wings..."

TOKEN="$1"

if [ -z "$TOKEN" ]; then
echo "Token wings tidak diberikan!"
exit 1
fi

eval "$TOKEN"

echo "Restart wings..."

systemctl daemon-reload
systemctl enable wings
systemctl restart wings

sleep 2

echo "Status wings:"
systemctl status wings --no-pager

echo "================================"
echo "WINGS SELESAI DIJALANKAN"
echo "================================"
