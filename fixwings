#!/bin/bash

# Warna untuk output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

clear
echo -e "${GREEN}================================${NC}"
echo -e "${GREEN}   AUTO FIX WINGS PTERODACTYL   ${NC}"
echo -e "${GREEN}================================${NC}"
echo ""

# Fungsi untuk logging
log() {
    echo -e "${BLUE}[$(date '+%H:%M:%S')]${NC} $1"
}

# Fungsi untuk mengecek error
check_error() {
    if [ $? -ne 0 ]; then
        echo -e "${RED}❌ Error: $1${NC}"
        exit 1
    fi
}

log "${YELLOW}Step 1/8: Update package...${NC}"
apt update -y > /dev/null 2>&1
check_error "Gagal update package"

log "${YELLOW}Step 2/8: Install dependencies...${NC}"
apt install -y curl wget sudo iptables openssl tar unzip ufw expect > /dev/null 2>&1
check_error "Gagal install dependencies"

log "${YELLOW}Step 3/8: Install Docker...${NC}"
if ! command -v docker &> /dev/null; then
    curl -fsSL https://get.docker.com -o get-docker.sh
    sh get-docker.sh > /dev/null 2>&1
    check_error "Gagal install docker"
    rm get-docker.sh
else
    log "${GREEN}✓ Docker sudah terinstall${NC}"
fi

systemctl start docker
systemctl enable docker > /dev/null 2>&1

if systemctl is-active --quiet docker; then
    log "${GREEN}✓ Docker running${NC}"
else
    log "${RED}Docker tidak running, restarting...${NC}"
    systemctl restart docker
    sleep 3
fi

log "${YELLOW}Step 4/8: Install Wings...${NC}"
# Backup config jika ada
[ -f /etc/pterodactyl/config.yml ] && cp /etc/pterodactyl/config.yml /etc/pterodactyl/config.yml.backup

rm -f /usr/local/bin/wings
curl -L -o /usr/local/bin/wings https://github.com/pterodactyl/wings/releases/latest/download/wings_linux_amd64 > /dev/null 2>&1
check_error "Gagal download wings"
chmod +x /usr/local/bin/wings
check_error "Gagal set permission wings"

log "${GREEN}✓ Wings berhasil diinstall${NC}"

log "${YELLOW}Step 5/8: Setup folder structure...${NC}"
mkdir -p /etc/pterodactyl /var/lib/pterodactyl/volumes /var/log/pterodactyl /var/run/pterodactyl
chmod -R 755 /etc/pterodactyl /var/lib/pterodactyl /var/log/pterodactyl /var/run/pterodactyl

log "${YELLOW}Step 6/8: Generate SSH host key...${NC}"
ssh-keygen -A > /dev/null 2>&1
systemctl restart ssh > /dev/null 2>&1

log "${YELLOW}Step 7/8: Setup systemd service...${NC}"
cat > /etc/systemd/system/wings.service <<EOF
[Unit]
Description=Pterodactyl Wings Daemon
After=docker.service network-online.target
Requires=docker.service
Wants=network-online.target

[Service]
User=root
WorkingDirectory=/etc/pterodactyl
LimitNOFILE=65536
LimitNPROC=65536
TasksMax=infinity
PIDFile=/var/run/pterodactyl/wings.pid
ExecStart=/usr/local/bin/wings
ExecReload=/bin/kill -SIGTERM \$MAINPID
Restart=on-failure
RestartSec=5
EnvironmentFile=-/etc/pterodactyl/wings.conf

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable wings > /dev/null 2>&1
log "${GREEN}✓ Service wings siap${NC}"

# Buat script helper untuk auto-configure
cat > /usr/local/bin/configure-wings <<'EOF'
#!/bin/bash
if [ $# -eq 0 ]; then
    echo "Usage: configure-wings [token_command]"
    exit 1
fi

cd /etc/pterodactyl
rm -f config.yml

# Gunakan expect untuk handle prompt otomatis
expect << EOD
set timeout 30
spawn $@
expect {
    "*Override existing*" { send "y\r"; exp_continue }
    "*y/N*" { send "y\r"; exp_continue }
    eof
}
EOD

# Cek hasil
if [ -f config.yml ]; then
    echo "✅ Konfigurasi berhasil!"
    systemctl restart wings
    sleep 2
    systemctl status wings --no-pager | grep "Active:"
else
    echo "❌ Konfigurasi gagal!"
    exit 1
fi
EOF

chmod +x /usr/local/bin/configure-wings

echo ""
echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}   WINGS FIX COMPLETE! (AUTO-ANSWER)   ${NC}"
echo -e "${GREEN}========================================${NC}"
echo ""
echo -e "${YELLOW}Status:${NC}"
systemctl is-active --quiet docker && echo -e "✅ Docker: ${GREEN}Running${NC}" || echo -e "❌ Docker: ${RED}Not Running${NC}"
echo -e "✅ Wings Service: ${GREEN}Enabled${NC}"
echo ""
echo -e "${YELLOW}Cara pakai (OTOMATIS JAWAB PROMPT):${NC}"
echo -e "${GREEN}configure-wings wings configure --panel https://domain.com --token pta_xxxxx --node 1${NC}"
echo ""
echo -e "${YELLOW}Atau manual dengan auto-answer:${NC}"
echo -e "${GREEN}cd /etc/pterodactyl && rm -f config.yml && echo \"y\" | [token_command] && systemctl restart wings${NC}"
echo ""
echo -e "${GREEN}========================================${NC}"
