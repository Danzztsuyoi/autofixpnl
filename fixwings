#!/bin/bash

clear
echo "================================"
echo "AUTO FIX WINGS PTERODACTYL"
echo "================================"

sleep 2

echo "Memastikan docker aktif..."

systemctl start docker 2>/dev/null
systemctl enable docker 2>/dev/null

if ! systemctl is-active --quiet docker; then
echo "Docker belum ada, install docker..."
curl -fsSL https://get.docker.com | sh

systemctl daemon-reload
systemctl enable docker
systemctl start docker
fi

echo "Docker status:"
systemctl is-active docker

echo "Menyiapkan folder wings..."

mkdir -p /etc/pterodactyl

echo "Menghapus config lama..."

rm -f /etc/pterodactyl/config.yml

echo "================================"
echo "Cek SSL Node..."
echo "================================"

DOMAIN=$(grep -oP 'https://\K[^ ]+' /etc/pterodactyl/config.yml 2>/dev/null)

if [ -n "$DOMAIN" ]; then

if [ ! -d "/etc/letsencrypt/live/$DOMAIN" ]; then

echo "SSL belum ada, membuat SSL untuk $DOMAIN"

apt install certbot -y

certbot certonly --standalone -d $DOMAIN --non-interactive --agree-tos -m admin@$DOMAIN

else

echo "SSL sudah ada"

fi

fi

echo "================================"
echo "FIX WINGS SELESAI"
echo "================================"
